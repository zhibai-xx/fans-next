# 本地开发环境模板
# 复制为 .env.local 后填写真实本地值，不要直接在本文件中写入真实密钥。

NEXTAUTH_URL="http://localhost:3001"
NEXTAUTH_SECRET="replace-with-a-local-nextauth-secret"

NEXT_PUBLIC_API_URL="http://localhost:3000/api"
NEXT_PUBLIC_SITE_URL="http://localhost:3001"
NEXT_PUBLIC_PRIMARY_TALENT_SLUG=joy-star
NEXT_PUBLIC_ENABLE_VIDEO_FEATURE=false

# Next.js 服务端访问后端时使用
BACKEND_INTERNAL_ORIGIN="http://127.0.0.1:3000"
